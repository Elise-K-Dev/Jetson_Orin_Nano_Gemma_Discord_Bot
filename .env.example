DISCORD_TOKEN=your-bot-token
DISCORD_PUBLIC_KEY=836a1c9c75085227d14313c5a4efaef319659749701d94890e20c84892c3e368

# Optional: set this while developing so slash commands update immediately.
DISCORD_GUILD_ID=your-test-guild-id

# Optional: read normal channel messages and answer when mentioned by name.
# Requires Message Content Intent in the Discord Developer Portal.
DISCORD_CHAT_LISTENER=0

# Optional: let the model use Discord Markdown, including compact tables.
DISCORD_MARKDOWN_OUTPUT=1

# Optional: include recent channel messages when replying to mentions.
DISCORD_CONTEXT_MESSAGES=8
DISCORD_CONTEXT_CHARS=2400

# Optional: comma-separated names that also trigger chat replies.
DISCORD_TRIGGER_NAMES=코미

# Optional: remember user questions and periodically summarize them.
MEMORY_ENABLED=0
MEMORY_CAPTURE_ALL_CHAT=0
MEMORY_DIR=memory
MEMORY_SUMMARIZE_EVERY=20
MEMORY_SUMMARY_CHARS=1600
MEMORY_RETAIN_RAW_LOGS=0
MEMORY_MAX_LOG_CHARS=20000
MEMORY_ENTRY_CHARS=500
MEMORY_STORE_AUTHOR_NAMES=0

# Optional: attach web search snippets when users ask for search/latest/current info.
WEB_SEARCH_ENABLED=0
WEB_SEARCH_ALWAYS=0
WEB_SEARCH_RESULTS=5
WEB_FETCH_LINKS=1
WEB_FETCH_MAX_URLS=3
WEB_FETCH_CHARS=2400
WEB_FETCH_BODY_BYTES=524288
WEB_CRAWL_LINKS=0
WEB_CRAWL_MAX_PAGES=2
WEB_CRAWL_CHARS=700

# llama.cpp llama-server, for example:
# llama-server --host 0.0.0.0 --port 8080 -hf unsloth/gemma-4-E2B-it-GGUF:Q4_K_S
LLAMA_BASE_URL=http://127.0.0.1:8080
LLAMA_MODEL=local-gemma
LLAMA_SYSTEM_PROMPT_FILE=prompts/system.md
# LLAMA_SYSTEM_PROMPT=You are a concise Discord assistant running locally on a Jetson.
LLAMA_TIMEOUT_SECS=120
LLAMA_MAX_TOKENS=512
LLAMA_PROMPT_CHARS=5000
LLAMA_THINKING_MODE=off
